# ============================================
# Petronix Production Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env

# ⚠️ ОБЯЗАТЕЛЬНО: IP адрес или домен вашего сервера
# Без этого фронтенд не сможет обращаться к API!
SERVER_HOST=YOUR_SERVER_IP

# Пароль базы данных (по умолчанию: adminsecret)
DB_PASSWORD=adminsecret

# JWT секретный ключ (поменяйте на свой!)
JWT_SECRET=petronix-super-secret-key-2026

# Telegram бот для заявок (оставьте как есть если ваш бот)
TELEGRAM_BOT_TOKEN=8591029476:AAEGZBysaWCgrzyZNwAdFi8wl4Q9kEFl1Pk
TELEGRAM_CHAT_ID=-4912475701
